{
  "name": "eon-next-frontend",
  "private": true,
  "version": "0.0.0",
  "description": "Frontend panel and Lovelace cards for the EON Next integration",
  "type": "module",
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "dev": "rollup -c rollup.config.mjs --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,css}' 'dev/**/*.{html,js}'",
    "format:check": "prettier --check 'src/**/*.{ts,css}' 'dev/**/*.{html,js}'",
    "typecheck": "tsc --noEmit",
    "build:check": "git diff --exit-code -- ../custom_components/eon_next/frontend/entrypoint.js ../custom_components/eon_next/frontend/cards.js",
    "codegen": "python3 ../scripts/generate_ts_api.py",
    "codegen:check": "python3 ../scripts/generate_ts_api.py && git diff --exit-code src/api.generated.ts"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "rollup": "^4.62.2",
    "rollup-plugin-lit-css": "^6.0.1",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-serve": "^3.0.0",
    "tslib": "^2.8.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.62.1"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "date-fns": "^4.4.0",
    "lit": "^3.3.3"
  }
}
